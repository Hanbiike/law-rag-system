# =============================================================================
# Law RAG System — Environment Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure OpenAI — Primary deployment (GPT-4o / GPT-5-mini or similar)
# Used for high-quality responses and document/image queries.
# -----------------------------------------------------------------------------
AZURE_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_DEPLOYMENT=gpt-4o
AZURE_API_VERSION=2025-03-01-preview

# -----------------------------------------------------------------------------
# Azure OpenAI — Nano deployment (fast/cheap model for routing & expansion)
# Used for RAG decision routing and query expansion.
# -----------------------------------------------------------------------------
AZURE_ENDPOINT_NANO=https://<your-nano-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY_NANO=<your-nano-azure-openai-api-key>
AZURE_DEPLOYMENT_NANO=gpt-4o-mini
AZURE_API_VERSION_NANO=2025-03-01-preview

# -----------------------------------------------------------------------------
# Telegram Bot
# Obtain the token from @BotFather on Telegram.
# Required only when running run_bot.py.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>

# -----------------------------------------------------------------------------
# MySQL Database
# Used for storing user data (balances, language preferences, etc.).
# Required only when the Telegram bot or user management is enabled.
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=<your-db-password>
DB_NAME=law_rag_users

# -----------------------------------------------------------------------------
# FastAPI Backend Server
# Controls the host/port that run_api.py and run_service.py bind to.
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Number of Uvicorn worker processes (ignored in dev/reload mode).
API_WORKERS=1

# -----------------------------------------------------------------------------
# Next.js Frontend
# Controls the port the Next.js dev/production server listens on.
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000

# URL of the FastAPI backend as seen by the Next.js server (SSR/API routes).
# In production set this to the public or internal URL of the backend.
# Defaults to http://localhost:8000 when not set.
LAW_RAG_API_URL=http://localhost:8000

# Default UI theme applied before the user selects one.
# Possible values depend on the theme presets defined in the frontend.
# Leave empty to use the built-in default.
NEXT_PUBLIC_DEFAULT_THEME=
